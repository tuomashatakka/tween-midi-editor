{
  "name": "tween-midi-editor",
  "productName": "Tween MIDI Editor",
  "version": "1.0.0",
  "description": "A zoomable, canvas-based MVP MIDI piano-roll editor with Ableton-style tools and Web Audio oscillator playback.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "ELECTRON=1 vite",
    "electron:build": "tsc -b && vite build && electron-builder"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "redux-undo": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.1.0",
    "@tuomashatakka/eslint-config": "^3.2.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "playwright-core": "^1.60.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.8"
  },
  "build": {
    "productName": "Tween MIDI Editor",
    "appId": "org.tween.midieditor",
    "files": [
      "dist/",
      "dist-electron/",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ]
    }
  },
  "license": "MIT"
}
